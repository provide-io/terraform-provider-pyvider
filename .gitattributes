# Enforce Unix line endings for all files
* text=auto eol=lf

# Explicitly set line endings for specific file types
*.py text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Binary files
*.bin binary
*.exe binary
*.psp binary
*.zip binary
